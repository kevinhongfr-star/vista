{
  "buildCommand": "npm run build",
  "framework": "nextjs",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "app/api/**/*.{js,ts,jsx,tsx}": {
      "runtime": "@vercel/node@3.0.10",
      "memory": 1024,
      "maxDuration": 300
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
